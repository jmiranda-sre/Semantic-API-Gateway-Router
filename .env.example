# ── Application ──
APP_NAME=semantic-api-gateway
APP_ENV=development
APP_PORT=3000
APP_VERSION=1.0.0

# ── Security ──
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ISSUER=semantic-gateway
JWT_AUDIENCE=semantic-gateway
JWT_EXPIRY=900
ADMIN_API_KEY=change-me-admin-key-min-32-chars

# ── Embeddings ──
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_CACHE_TTL=3600
EMBEDDING_CACHE_MAX=10000

# ── Vector Index ──
HNSW_M=16
HNSW_EF_CONSTRUCTION=200
HNSW_EF_SEARCH=50

# ── Routing ──
CONFIDENCE_THRESHOLD=0.85
CONFLICT_MARGIN=0.05
ROUTER_TIMEOUT_MS=5000

# ── Proxy ──
PROXY_TIMEOUT_MS=30000
PROXY_MAX_SOCKETS=100

# ── Monitoring ──
LOG_LEVEL=info
METRICS_ENABLED=true

# ── CORS ──
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ──
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=900000
